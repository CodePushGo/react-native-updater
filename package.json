{
  "name": "@codepush-go/react-native-updater",
  "version": "7.0.50",
  "license": "MPL-2.0",
  "description": "Live updates for React Native apps",
  "main": "dist/index.js",
  "module": "dist/index.mjs",
  "react-native": "src/index.ts",
  "types": "dist/esm/index.d.ts",
  "files": [
    "dist/",
    "src/",
    "ios/",
    "android/",
    "react-native-updater.podspec",
    "react-native.config.js"
  ],
  "author": "Martin Donadieu <martin@capgo.app>",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/codepush-go/react-native-updater.git"
  },
  "bugs": {
    "url": "https://github.com/codepush-go/react-native-updater/issues"
  },
  "keywords": [
    "react-native",
    "codepush",
    "code push",
    "live updates",
    "ota",
    "updater",
    "codepushgo"
  ],
  "scripts": {
    "verify": "bun run verify:ios && bun run verify:android && bun run verify:web",
    "verify:ios": "cd ios && pod install && xcodebuild -workspace Plugin.xcworkspace -scheme Plugin -destination generic/platform=iOS && cd ..",
    "verify:android": "cd android && ./gradlew clean build test && cd ..",
    "verify:web": "bun run build",
    "lint": "bun run eslint && bun run prettier -- --check",
    "fmt": "bun run eslint -- --fix && bun run prettier -- --write",
    "eslint": "eslint src --ext .ts",
    "prettier": "prettier \"src/**/*.{ts,js}\" \"android/src/**/*.java\" --plugin=prettier-plugin-java",
    "build": "bun run clean && tsc && rollup -c rollup.config.mjs",
    "clean": "rimraf ./dist",
    "watch": "tsc --watch",
    "prepublishOnly": "bun run build"
  },
  "devDependencies": {
    "@types/node": "^22.13.1",
    "@types/react": "^19.0.11",
    "@types/react-native": "^0.73.0",
    "@typescript-eslint/parser": "^8.25.0",
    "eslint": "^8.57.0",
    "eslint-plugin-import": "^2.31.0",
    "husky": "^9.1.7",
    "prettier": "^3.4.2",
    "prettier-plugin-java": "^2.6.7",
    "react": "*",
    "react-native": "*",
    "rimraf": "^6.0.1",
    "rollup": "^4.18.0",
    "rollup-plugin-typescript2": "^0.36.0",
    "typescript": "~5.4.5"
  },
  "peerDependencies": {
    "react": "*",
    "react-native": "*"
  }
}
